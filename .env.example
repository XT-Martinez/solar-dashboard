# Inverter Modbus TCP endpoint on the local network.
INVERTER_HOST=192.168.254.152

# Telegraf polling and InfluxDB flush interval.
POLL_INTERVAL=5s

# Sungrow inside temperature register. Use 5008 if your client path is not zero-offset.
INSIDE_TEMP_REGISTER=5007

# InfluxDB organization, raw bucket, and admin token used by Telegraf, Grafana, and retention setup.
INFLUX_ORG=solar
INFLUX_BUCKET=solar
INFLUX_TOKEN=solar-token

# Initial InfluxDB admin credentials used only when the volume is first initialized.
INFLUX_USERNAME=admin
INFLUX_PASSWORD=change-me-solar

# Raw bucket retention. 2160h is 90 days.
INFLUX_RAW_RETENTION=2160h

# Downsampled bucket, interval, and retention. 17520h is 2 years.
INFLUX_DOWNSAMPLED_BUCKET=solar_1h
INFLUX_DOWNSAMPLE_EVERY=1h
INFLUX_DOWNSAMPLED_RETENTION=17520h

# InfluxDB task name for hourly downsampling.
INFLUX_DOWNSAMPLE_TASK=downsample-solar-1h

# Grafana login credentials.
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=admin
