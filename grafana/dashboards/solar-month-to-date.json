      "targets": [
        {
          "query": "import \"date\"\n\nmonthStart = time(v: \"${month}-01T00:00:00Z\")\nmonthStop = date.add(d: 1mo, to: monthStart)\nrate = float(v: \"${electricity_rate}\")\n\nfrom(bucket: \"solar_1h\")\n  |> range(start: monthStart, stop: monthStop)\n  |> filter(fn: (r) => r._measurement == \"sungrow_energy\")\n  |> filter(fn: (r) => contains(value: r._field, set: [\"consumption_kwh\", \"grid_import_kwh\"]))\n  |> group(columns: [\"_field\"])\n  |> sum()\n  |> map(fn: (r) => ({ r with metric: if r._field == \"consumption_kwh\" then \"consumed\" else \"grid\" }))\n  |> keep(columns: [\"metric\", \"_value\"])\n  |> group()\n  |> pivot(rowKey: [], columnKey: [\"metric\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({ r with self_consumed: if r.consumed > r.grid then r.consumed - r.grid else 0.0 }))\n  |> map(fn: (r) => ({ r with _value: r.self_consumed * rate }))\n  |> keep(columns: [\"_value\"])",
          "refId": "A"
        }
      ],
      "title": "Est. savings vs no solar",
      "type": "stat"
