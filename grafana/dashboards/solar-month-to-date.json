          "query": "import \"date\"\nimport \"strings\"\n\nmonthStart = time(v: \"${month}-01T00:00:00+08:00\")\nmonthStop = date.add(d: 1mo, to: monthStart)\n\nfrom(bucket: \"solar_1h\")\n  |> range(start: monthStart, stop: monthStop)\n  |> filter(fn: (r) => r._measurement == \"sungrow_energy\" and r._field == \"production_kwh\")\n  |> timeShift(duration: 8h)\n  |> window(every: 1d)\n  |> sum()\n  |> map(fn: (r) => ({ r with _time: r._start }))\n  |> window(every: inf)\n  |> max()\n  |> map(fn: (r) => ({ r with _field: strings.substring(v: string(v: r._time), start: 0, end: 10) }))",
